# 특허시세 환경변수 예시 — .env.local 로 복사 후 값 입력

# Claude(여신심사 메모 생성)용 Anthropic API 키
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# KIPRIS Plus 포털(plus.kipris.or.kr) 직접 발급 AccessKey — 1순위 호출에 사용
# 키 인식 후 resultCode 31(DEADLINE_HAS_EXPIRED = 상품 미신청)이면 2순위(data.go.kr)로 자동 폴백
# 상품 신청 완료 후 즉시 실데이터 전환 (코드 수정 불필요)
KIPRIS_PLUS_ACCESS_KEY=발급받은_KIPRIS_Plus_AccessKey_입력

# data.go.kr KIPRIS 계열 OpenAPI 인증키 — 2순위(KIPRIS Plus 실패 시 폴백)
# ※ 키가 없거나 resultCode 30(SERVICE KEY IS NOT REGISTERED) 반환 시 샘플 자동 폴백
DATA_GO_KR_SERVICE_KEY=발급받은_서비스키_입력
